# AI Gateway Environment Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Anthropic API Configuration
# ============================================
# Your Anthropic API Key for proxying requests
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============================================
# Admin Configuration
# ============================================
# Admin API Key for management operations
# Generate this after first deployment via admin API
ADMIN_API_KEY=

# ============================================
# Gateway Configuration
# ============================================
# Gateway base URL (for testing)
GATEWAY_BASE_URL=http://localhost:8787

# Environment (development | production)
ENVIRONMENT=development
