# AI Gateway Environment Template
# Copy this file to .env.local and fill in your actual values

# ============================================
# Anthropic API Configuration
# ============================================
# Your Anthropic API Key for proxying requests
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Anthropic API Base URL (usually https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model ID to use for testing (e.g., claude-3-5-haiku-20241022)
TEST_MODEL_ID=claude-3-5-haiku-20241022

# ============================================
# Admin Configuration
# ============================================
# Admin API Key for management operations
#
# 获取方式:
# 1. 启动开发服务器: npm run dev
# 2. 初始化数据库: npm run db:migrate:local && npm run db:seed:local
# 3. 运行初始化脚本生成 Admin Key: ./scripts/init-dev-keys.sh
# 4. 或直接运行 E2E 测试: ./tests/e2e/run.sh (会自动创建测试用 Admin Key)
#
ADMIN_API_KEY=

# ============================================
# Gateway Configuration
# ============================================
# Gateway base URL (for testing)
GATEWAY_BASE_URL=http://localhost:8787

# Environment (development | production)
ENVIRONMENT=development

# ============================================
# 测试用户配置（可选）
# ============================================
# 测试用的公司 ID（如果不填，E2E 测试会自动生成）
TEST_COMPANY_ID=

# 测试用的部门 ID（如果不填，E2E 测试会自动生成）
TEST_DEPARTMENT_ID=

# 测试用的用户 ID（如果不填，E2E 测试会自动生成）
TEST_USER_ID=

