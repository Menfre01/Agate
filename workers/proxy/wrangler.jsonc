{
  "name": "agate-proxy",
  "compatibility_date": "2024-01-01",
  "main": "src/index.ts",
  "compatibility_flags": ["nodejs_compat"],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agate-db",
      "database_id": "local",
      "migrations_dir": "../../migrations"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "KV_CACHE",
      "id": "local",
      "preview_id": "local"
    }
  ],

  "vars": {
    "ENVIRONMENT": "development"
  },

  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.ts"],
      "fallthrough": true
    }
  ],

  "dev": {
    "port": 8787,
    "local_protocol": "http"
  },

  "observability": {
    "enabled": true
  },

  "routes": [
    {
      "pattern": "proxy.your-gateway.example.com/*",
      "zone_name": "example.com"
    }
  ]
}
