{
  "name": "agate",
  "version": "0.1.0",
  "description": "Agate — Your AI Gateway for proxying Anthropic API requests with multi-tenant management",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "pnpm dev:start",
    "dev:start": "bash scripts/dev-start.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:status": "bash scripts/dev-status.sh",
    "dev:logs": "bash scripts/dev-logs.sh",
    "dev:clean": "bash scripts/dev-clean.sh",
    "dev:all": "npm-run-all --parallel dev:proxy dev:admin",
    "dev:proxy": "npm run dev --workspace=workers/proxy",
    "dev:admin": "npm run dev --workspace=workers/admin",
    "dev:health": "npm run dev --workspace=workers/health",
    "deploy": "npm run deploy:all",
    "deploy:all": "npm run deploy:proxy && npm run deploy:admin && npm run deploy:health",
    "deploy:proxy": "npm run deploy --workspace=workers/proxy",
    "deploy:admin": "npm run deploy --workspace=workers/admin",
    "deploy:health": "npm run deploy --workspace=workers/health",
    "deploy:proxy:prod": "cd workers/proxy && wrangler deploy --config wrangler.prod.jsonc",
    "deploy:admin:prod": "cd workers/admin && wrangler deploy --config wrangler.prod.jsonc",
    "deploy:health:prod": "cd workers/health && wrangler deploy --config wrangler.prod.jsonc",
    "test": "TEST_CLEANUP=true vitest",
    "test:ui": "npm-run-all dev:start --silent test:ui:run --silent dev:stop",
    "test:ui:run": "TEST_CLEANUP=true vitest --ui",
    "test:coverage": "npm-run-all dev:start --silent test:coverage:run dev:stop",
    "test:coverage:run": "TEST_CLEANUP=true vitest --run --coverage",
    "test:unit": "vitest tests/unit",
    "test:integration": "vitest tests/integration",
    "test:functional": "npm-run-all dev:start --silent test:functional:run dev:stop",
    "test:functional:run": "TEST_CLEANUP=true vitest tests/functional --run",
    "test:functional:coverage": "npm-run-all dev:start --silent test:functional:run:coverage dev:stop",
    "test:functional:run:coverage": "TEST_CLEANUP=true vitest tests/functional --run --coverage",
    "smoke-test": "bash tests/smoke-test.sh",
    "smoke-test:local": "bash tests/smoke-test.sh http://localhost:8787 http://localhost:8788",
    "db:migrate": "npx wrangler d1 migrations apply agate-db --local",
    "db:migrate:prod": "npx wrangler d1 migrations apply agate-db --remote --config=workers/proxy/wrangler.prod.jsonc",
    "db:migration:create": "npx wrangler d1 migrations create agate-db --local",
    "db:migration:list": "npx wrangler d1 migrations list agate-db --local",
    "db:migration:list:prod": "npx wrangler d1 migrations list agate-db --remote --config=workers/proxy/wrangler.prod.jsonc",
    "db:seed": "wrangler d1 execute ai-gateway-db --file=./scripts/seed-data.sql",
    "db:seed:local": "wrangler d1 execute ai-gateway-db --file=./scripts/seed-data.sql --local",
    "db:seed:system": "wrangler d1 execute ai-gateway-db --file=./scripts/seed-system-user.sql",
    "db:seed:system:local": "wrangler d1 execute ai-gateway-db --file=./scripts/seed-system-user.sql --local",
    "db:query": "wrangler d1 execute ai-gateway-db --command",
    "db:query:local": "wrangler d1 execute ai-gateway-db --command --local",
    "typecheck": "tsc --noEmit",
    "typecheck:proxy": "npm run typecheck --workspace=workers/proxy",
    "typecheck:admin": "npm run typecheck --workspace=workers/admin",
    "typecheck:health": "npm run typecheck --workspace=workers/health",
    "typecheck:all": "npm run typecheck --workspaces"
  },
  "keywords": [
    "agate",
    "ai-gateway",
    "anthropic",
    "cloudflare-workers"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.76.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
