{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "jsx": "preserve",
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "removeComments": false,
    "emitDecoratorMetadata": false,
    "experimentalDecorators": false,
    "baseUrl": ".",
    "paths": {
      "@/types": ["packages/shared/src/types"],
      "@/types/*": ["packages/shared/src/types/*"],
      "@/utils": ["packages/shared/src/utils"],
      "@/utils/*": ["packages/shared/src/utils/*"],
      "@/db": ["packages/shared/src/db"],
      "@/db/*": ["packages/shared/src/db/*"],
      "@/middleware": ["packages/shared/src/middleware"],
      "@/middleware/*": ["packages/shared/src/middleware/*"],
      "@/api": ["workers/admin/src/api"],
      "@/api/*": ["workers/admin/src/api/*"],
      "@/api/proxy": ["workers/proxy/src/api/proxy"],
      "@/api/proxy/*": ["workers/proxy/src/api/proxy/*"],
      "@/services": ["workers/admin/src/services"],
      "@/services/*": ["workers/admin/src/services/*"],
      "@agate/shared": ["packages/shared/src"],
      "@agate/shared/*": ["packages/shared/src/*"],
      "@agate/proxy": ["workers/proxy/src"],
      "@agate/proxy/*": ["workers/proxy/src/*"],
      "@agate/admin": ["workers/admin/src"],
      "@agate/admin/*": ["workers/admin/src/*"],
      "@agate/health": ["workers/health/src"],
      "@agate/health/*": ["workers/health/src/*"],
      "@test/helpers": ["tests/functional/helpers"],
      "@test/helpers/*": ["tests/functional/helpers/*"],
      "@test/integration": ["tests/integration"],
      "@test/integration/*": ["tests/integration/*"]
    }
  },
  "include": [
    "packages/shared/src/**/*",
    "workers/proxy/src/**/*",
    "workers/admin/src/**/*",
    "workers/health/src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".wrangler"
  ]
}
