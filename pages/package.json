{
  "name": "agate-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "TEST_CLEANUP=true vitest",
    "test:ui": "TEST_CLEANUP=true vitest --ui",
    "test:coverage": "TEST_CLEANUP=true vitest --coverage",
    "test:unit": "TEST_CLEANUP=true vitest tests/unit",
    "test:integration": "TEST_CLEANUP=true vitest tests/integration",
    "test:e2e": "TEST_CLEANUP=true playwright test",
    "test:e2e:ui": "TEST_CLEANUP=true playwright test --ui",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.5",
    "@playwright/test": "^1.49.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.4.0",
    "jsdom": "^25.0.1",
    "msw": "^2.6.4",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@vicons/antd": "^0.13.0",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "4"
  }
}
